//Given the head of a linked list and an integer val, remove all the nodes of the linked list that has Node.val == val, and return the new head.
//Example 1:
//Input: head = [1,2,6,3,4,5,6], val = 6
//Output: [1,2,3,4,5]
//Example 2:
//Input: head = [], val = 1
//Output: []
//Example 3:
//Input: head = [7,7,7,7], val = 7
//Output: []
//Constraints:
//The number of nodes in the list is in the range [0, 104].
//1 <= Node.val <= 50
//0 <= val <= 50



Brute force ->

class Solution {
public:
    ListNode* removeElements(ListNode* head, int val) {                      // ListNode* = function returns a pointer to a ListNode (the new head of the linked list).

        vector<int> values;                                             

        ListNode* current = head;

        while(current != nullptr) {                                        
            if(current->val != val) {                                          // If the value stored in the current node is not equal to val(Similar to (*current).val), then push it in values.
                values.push_back(current->val);
            }
            current = current->next;                                           // Move to the next node in the linked list.
        }

        ListNode dummy(0);                                                       
        ListNode* tail = &dummy;                                                 // tail points to dummy, so [0] -> nullptr.
        for(int num : values) {
            tail->next = new ListNode(num);
            tail = tail->next;
        }

        return dummy.next;                                                      //Return the actual head of the new list, skipping the dummy node.
    }
};


Complexity Analysis ->
Time Complexity - O(n)
Space Complexity - O(n)

Optimal Approach ->                     // Modify the existing linked list instead of creating a new one.

class Solution {
public:
    ListNode* removeElements(ListNode* head, int val) {
        ListNode dummy(0);
        dummy.next = head;                               // dummy points to the head of the linked list
        ListNode* current = &dummy;                     // current points to dummy
        while(current->next != nullptr) {
            if(current->next->val == val) {
                current->next = current->next->next;         // If list is [1](current) -> [2](current->next) -> [3](current->next->next) , then it becomes [1](current) -> [3] 
}
            else {
                current = current->next;
            }
        }
        return dummy.next;
    }
};

Complexity Analysis ->
Time Complexity - O(n)
Space Complexity - O(1)

Corner Cases ->
1. Empty List
2. No Node Needs Removal
3. Multiple Consecutive Nodes
4. Head node is the value that needs to be removed          // This is the reason we use dummy node.
5. Entire List Must Be Removed                              //Example:
                                                            //head = [7,7,7,7]
                                                            //val = 7
